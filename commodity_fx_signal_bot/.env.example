
# Scan & Time Settings
DEFAULT_TIMEZONE=Europe/Istanbul
DEFAULT_SCAN_PROFILE=balanced_swing
ENABLE_MARKET_SESSION_FILTER=true
ALLOW_DERIVED_TIMEFRAMES=true
MAX_SCAN_PLAN_SYMBOLS=80

# Phase 6: Data Cleaning and Quality Settings
PROCESSED_DATA_ENABLED=true
CLEANING_ENABLED=true
OUTLIER_DETECTION_ENABLED=true
DEFAULT_QUALITY_MIN_ROWS=50
DEFAULT_OUTLIER_RETURN_THRESHOLD=0.20
DEFAULT_OUTLIER_ZSCORE_THRESHOLD=6.0
ALLOW_FORWARD_FILL_SMALL_GAPS=false
MAX_FORWARD_FILL_GAP=2
PRESERVE_RAW_DATA=true

# Phase 9: Trend Features & Events Settings
TREND_FEATURES_ENABLED=true
TREND_EVENTS_ENABLED=true
DEFAULT_TREND_MA_WINDOWS=10,20,50,100,200
DEFAULT_TREND_FAST_WINDOWS=10,20
DEFAULT_TREND_SLOW_WINDOWS=50,100,200
DEFAULT_ADX_THRESHOLD=25
DEFAULT_STRONG_ADX_THRESHOLD=35
DEFAULT_MACD_FAST=12
DEFAULT_MACD_SLOW=26
DEFAULT_MACD_SIGNAL=9
SAVE_TREND_FEATURES=true
SAVE_TREND_EVENTS=true

# Phase 13: Price Action Features & Events Settings
PRICE_ACTION_FEATURES_ENABLED=true
PRICE_ACTION_EVENTS_ENABLED=true
DEFAULT_PRICE_ACTION_WINDOWS=5,10,20,50
DEFAULT_BREAKOUT_WINDOWS=10,20,55
DEFAULT_LARGE_BODY_PERCENTILE_WINDOW=120
DEFAULT_LARGE_BODY_PERCENTILE_THRESHOLD=0.90
DEFAULT_LARGE_RANGE_PERCENTILE_THRESHOLD=0.90
DEFAULT_SMALL_RANGE_PERCENTILE_THRESHOLD=0.10
DEFAULT_WICK_REJECTION_RATIO=0.60
DEFAULT_STRONG_CLOSE_UPPER_THRESHOLD=0.80
DEFAULT_STRONG_CLOSE_LOWER_THRESHOLD=0.20
SAVE_PRICE_ACTION_FEATURES=true
SAVE_PRICE_ACTION_EVENTS=true
