
# Scan & Time Settings
DEFAULT_TIMEZONE=Europe/Istanbul
DEFAULT_SCAN_PROFILE=balanced_swing
ENABLE_MARKET_SESSION_FILTER=true
ALLOW_DERIVED_TIMEFRAMES=true
MAX_SCAN_PLAN_SYMBOLS=80

# Phase 6: Data Cleaning and Quality Settings
PROCESSED_DATA_ENABLED=true
CLEANING_ENABLED=true
OUTLIER_DETECTION_ENABLED=true
DEFAULT_QUALITY_MIN_ROWS=50
DEFAULT_OUTLIER_RETURN_THRESHOLD=0.20
DEFAULT_OUTLIER_ZSCORE_THRESHOLD=6.0
ALLOW_FORWARD_FILL_SMALL_GAPS=false
MAX_FORWARD_FILL_GAP=2
PRESERVE_RAW_DATA=true

# Phase 9: Trend Features & Events Settings
TREND_FEATURES_ENABLED=true
TREND_EVENTS_ENABLED=true
DEFAULT_TREND_MA_WINDOWS=10,20,50,100,200
DEFAULT_TREND_FAST_WINDOWS=10,20
DEFAULT_TREND_SLOW_WINDOWS=50,100,200
DEFAULT_ADX_THRESHOLD=25
DEFAULT_STRONG_ADX_THRESHOLD=35
DEFAULT_MACD_FAST=12
DEFAULT_MACD_SLOW=26
DEFAULT_MACD_SIGNAL=9
SAVE_TREND_FEATURES=true
SAVE_TREND_EVENTS=true

# Phase 13: Price Action Features & Events Settings
PRICE_ACTION_FEATURES_ENABLED=true
PRICE_ACTION_EVENTS_ENABLED=true
DEFAULT_PRICE_ACTION_WINDOWS=5,10,20,50
DEFAULT_BREAKOUT_WINDOWS=10,20,55
DEFAULT_LARGE_BODY_PERCENTILE_WINDOW=120
DEFAULT_LARGE_BODY_PERCENTILE_THRESHOLD=0.90
DEFAULT_LARGE_RANGE_PERCENTILE_THRESHOLD=0.90
DEFAULT_SMALL_RANGE_PERCENTILE_THRESHOLD=0.10
DEFAULT_WICK_REJECTION_RATIO=0.60
DEFAULT_STRONG_CLOSE_UPPER_THRESHOLD=0.80
DEFAULT_STRONG_CLOSE_LOWER_THRESHOLD=0.20
SAVE_PRICE_ACTION_FEATURES=true
SAVE_PRICE_ACTION_EVENTS=true

# Phase 14: Divergence Features & Events Settings
DIVERGENCE_FEATURES_ENABLED=true
DIVERGENCE_EVENTS_ENABLED=true
DEFAULT_DIVERGENCE_PIVOT_LEFT=3
DEFAULT_DIVERGENCE_PIVOT_RIGHT=3
DEFAULT_DIVERGENCE_LOOKBACK=80
DEFAULT_DIVERGENCE_MIN_PRICE_MOVE_PCT=0.005
DEFAULT_DIVERGENCE_MIN_INDICATOR_MOVE=0.0
DEFAULT_DIVERGENCE_CONFIRMATION_WINDOW=5
DEFAULT_DIVERGENCE_INDICATOR_COLUMNS=rsi_14,macd_hist_12_26_9,roc_10,obv,mfi_14,cmf_20
SAVE_DIVERGENCE_FEATURES=true
SAVE_DIVERGENCE_EVENTS=true

# Phase 15: MTF Settings
MTF_FEATURES_ENABLED=true
MTF_EVENTS_ENABLED=true
DEFAULT_MTF_BASE_TIMEFRAME=1d
DEFAULT_MTF_CONTEXT_TIMEFRAMES=4h,1d,1wk
DEFAULT_MTF_FEATURE_SETS=momentum,trend,volatility,mean_reversion,price_action,divergence
MTF_FORWARD_FILL_CONTEXT=true
MTF_MAX_CONTEXT_AGE_BARS=5
MTF_STRICT_NO_LOOKAHEAD=true
SAVE_MTF_FEATURES=true
SAVE_MTF_EVENTS=true

# Phase 16: Regime Classification Layer
REGIME_FEATURES_ENABLED=true
REGIME_EVENTS_ENABLED=true
DEFAULT_REGIME_PROFILE=balanced_regime
DEFAULT_REGIME_TIMEFRAME=1d
DEFAULT_REGIME_FEATURE_SETS=trend,momentum,volatility,mean_reversion,price_action,mtf
DEFAULT_ADX_TREND_THRESHOLD=25.0
DEFAULT_STRONG_TREND_THRESHOLD=35.0
DEFAULT_LOW_VOLATILITY_PERCENTILE=0.20
DEFAULT_HIGH_VOLATILITY_PERCENTILE=0.80
DEFAULT_RANGE_ADX_THRESHOLD=20.0
DEFAULT_REGIME_TRANSITION_LOOKBACK=5
SAVE_REGIME_FEATURES=true
SAVE_REGIME_EVENTS=true

# Paper Trading / Strategy
PAPER_TRADING_ENABLED=true

MACRO_FEATURES_ENABLED=true
MACRO_EVENTS_ENABLED=true
MACRO_DATA_ENABLED=true
DEFAULT_MACRO_FREQUENCY=monthly
DEFAULT_MACRO_START_DATE=2010-01-01
DEFAULT_MACRO_BASE_CURRENCY=TRY
USE_EVDS_FOR_TURKEY_MACRO=true
USE_FRED_FOR_US_MACRO=true
MACRO_FORWARD_FILL_TO_DAILY=true
MACRO_MAX_STALENESS_DAYS=45
BENCHMARK_FEATURES_ENABLED=true
SAVE_MACRO_FEATURES=true
SAVE_MACRO_EVENTS=true
SAVE_BENCHMARK_FEATURES=true
